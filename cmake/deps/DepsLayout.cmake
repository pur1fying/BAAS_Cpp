include_guard(GLOBAL)

function(baas_get_platform_key out_var)
    if(DEFINED TARGET_OS_NAME)
        set(_platform "${TARGET_OS_NAME}")
    elseif(CMAKE_SYSTEM_NAME STREQUAL "Darwin")
        set(_platform "MacOS")
    elseif(CMAKE_SYSTEM_NAME STREQUAL "Windows")
        set(_platform "Windows")
    elseif(CMAKE_SYSTEM_NAME STREQUAL "Android")
        set(_platform "Android")
    else()
        set(_platform "Linux")
    endif()

    if(_platform STREQUAL "Windows")
        set(_platform "Windows")
    elseif(_platform STREQUAL "MacOS" OR _platform STREQUAL "Darwin")
        set(_platform "MacOS")
    elseif(_platform STREQUAL "Android")
        set(_platform "Android")
    else()
        set(_platform "Linux")
    endif()

    set(${out_var} "${_platform}" PARENT_SCOPE)
endfunction()

function(baas_get_arch_key out_var)
    if(DEFINED ANDROID_ABI AND NOT ANDROID_ABI STREQUAL "")
        set(_arch "${ANDROID_ABI}")
    else()
        string(TOLOWER "${CMAKE_SYSTEM_PROCESSOR}" _arch)
        if(_arch STREQUAL "amd64" OR _arch STREQUAL "x86_64")
            set(_arch "x64")
        elseif(_arch STREQUAL "aarch64" OR _arch STREQUAL "arm64")
            set(_arch "arm64")
        endif()
    endif()

    set(${out_var} "${_arch}" PARENT_SCOPE)
endfunction()

function(baas_get_default_variant out_var)
    baas_get_platform_key(_platform)
    baas_get_arch_key(_arch)
    set(_compiler "${CMAKE_CXX_COMPILER_ID}")
    set(_config "${CMAKE_BUILD_TYPE}")

    if(_compiler STREQUAL "")
        set(_compiler "Unknown")
    endif()

    if(_config STREQUAL "")
        set(_config "Release")
    endif()

    set(${out_var} "${_platform}-${_arch}-${_compiler}-${_config}" PARENT_SCOPE)
endfunction()

function(baas_dependency_package_dir out_var name version)
    baas_get_default_variant(_variant)
    set(${out_var} "${BAAS_DEPS_ROOT}/${name}/${version}/${_variant}" PARENT_SCOPE)
endfunction()

function(baas_asset_package_dir out_var name version)
    set(${out_var} "${BAAS_ASSETS_ROOT}/${name}/${version}" PARENT_SCOPE)
endfunction()
