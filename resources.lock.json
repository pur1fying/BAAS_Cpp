{
  "schema": 1,
  "lock_type": "baas-cpp-resources",
  "paths": {
    "downloads": "${BAAS_DOWNLOADS_ROOT}",
    "package": "${BAAS_ASSETS_ROOT}/${name}/${version}/${provider}"
  },
  "state": {
    "file": "${BAAS_WORKSPACE_ROOT}/state.json"
  },
  "variant_model": {
    "fingerprint_inputs": [
      "name",
      "version",
      "provider",
      "sha256",
      "platform",
      "arch",
      "android_abi"
    ]
  },
  "resources": {
    "scrcpy_server": {
      "version": "TODO_CONFIRM",
      "provider": "release",
      "url": "TODO_LOCK_RELEASE_ASSET_URL",
      "sha256": "TODO_LOCK_SHA256",
      "fingerprint_inputs": [
        "version",
        "provider",
        "sha256",
        "platform",
        "arch"
      ],
      "outputs": {
        "runtime": [
          "scrcpy-server.jar"
        ]
      },
      "validation": {
        "required_outputs": [
          "runtime"
        ]
      }
    },
    "platform_tools_windows": {
      "version": "TODO_CONFIRM",
      "provider": "android_sdk",
      "url": "TODO_LOCK_PLATFORM_TOOLS_WINDOWS_URL",
      "sha256": "TODO_LOCK_SHA256",
      "fingerprint_inputs": [
        "version",
        "provider",
        "sha256",
        "platform",
        "arch"
      ],
      "outputs": {
        "runtime": [
          "platform-tools/adb.exe",
          "platform-tools/AdbWinApi.dll",
          "platform-tools/AdbWinUsbApi.dll"
        ]
      },
      "validation": {
        "required_outputs": [
          "runtime"
        ]
      }
    },
    "platform_tools_macos": {
      "version": "TODO_CONFIRM",
      "provider": "android_sdk",
      "url": "TODO_LOCK_PLATFORM_TOOLS_MACOS_URL",
      "sha256": "TODO_LOCK_SHA256",
      "fingerprint_inputs": [
        "version",
        "provider",
        "sha256",
        "platform",
        "arch"
      ],
      "outputs": {
        "runtime": [
          "platform-tools/adb"
        ]
      },
      "validation": {
        "required_outputs": [
          "runtime"
        ]
      }
    },
    "platform_tools_linux": {
      "version": "TODO_CONFIRM",
      "provider": "android_sdk",
      "url": "TODO_LOCK_PLATFORM_TOOLS_LINUX_URL",
      "sha256": "TODO_LOCK_SHA256",
      "fingerprint_inputs": [
        "version",
        "provider",
        "sha256",
        "platform",
        "arch"
      ],
      "outputs": {
        "runtime": [
          "platform-tools/adb"
        ]
      },
      "validation": {
        "required_outputs": [
          "runtime"
        ]
      }
    },
    "ascreencap": {
      "version": "TODO_CONFIRM",
      "provider": "external_asset",
      "url": "TODO_CONFIRM_UPSTREAM_OR_ASSET_URL",
      "sha256": "TODO_LOCK_SHA256",
      "fingerprint_inputs": [
        "version",
        "provider",
        "sha256",
        "platform",
        "arch",
        "android_abi"
      ],
      "outputs": {
        "runtime": [
          "Android_5.x-7.x/${android_abi}/ascreencap",
          "Android_8.x/${android_abi}/ascreencap",
          "Android_9.x/${android_abi}/ascreencap"
        ]
      },
      "validation": {
        "required_outputs": [
          "runtime"
        ]
      }
    },
    "ocr_models": {
