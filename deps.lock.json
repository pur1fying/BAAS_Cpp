          "archive_type": "tar.gz",
          "strip_prefix": "opencv-4.9.0"
        },
        "android_sdk": {
          "type": "archive",
          "url": "TODO_LOCK_OPENCV_ANDROID_SDK_URL",
          "sha256": "TODO_LOCK_SHA256",
          "archive_type": "zip"
        }
      },
      "provider_by_platform": {
        "windows": "source",
        "linux": "source",
        "macos": "source",
        "android": "android_sdk"
      },
      "fingerprint_inputs": [
        "version",
        "provider",
        "provider.sha256",
        "build.system",
        "build.cmake_options",
        "platform",
        "arch",
        "compiler.id",
        "compiler.version",
        "config",
        "toolchain_file"
      ],
      "build": {
        "system": "cmake",
        "package": true,
        "cmake_options": {
          "CMAKE_BUILD_TYPE": "${cmake_config}",
          "CMAKE_INSTALL_PREFIX": "${package}",
          "CMAKE_SYSTEM_PROCESSOR": "AMD64",
          "BUILD_SHARED_LIBS": "ON",
          "BUILD_opencv_world": "ON",
          "BUILD_TESTS": "OFF",
          "BUILD_PERF_TESTS": "OFF",
          "BUILD_EXAMPLES": "OFF",
          "BUILD_opencv_apps": "OFF",
          "BUILD_JAVA": "OFF",
          "BUILD_WITH_DEBUG_INFO": "OFF",
          "WITH_FFMPEG": "OFF",
          "WITH_GSTREAMER": "OFF",
          "WITH_OPENCL": "OFF",
          "WITH_OPENCLAMDBLAS": "OFF",
          "WITH_OPENCLAMDFFT": "OFF",
          "WITH_OPENCL_D3D11_NV": "OFF",
          "WITH_CUDA": "OFF",
          "WITH_IPP": "OFF",
          "WITH_JPEG": "OFF",
          "WITH_TIFF": "OFF",
          "WITH_WEBP": "OFF",
          "WITH_OPENEXR": "OFF",
          "WITH_OPENJPEG": "OFF",
          "WITH_JASPER": "OFF",
          "WITH_PNG": "ON",
          "BUILD_PNG": "ON",
          "OPENCV_DNN_CUDA": "OFF",
          "OPENCV_DNN_OPENCL": "OFF",
          "OPENCV_DNN_TFLITE": "OFF",
          "OPENCV_ENABLE_ALLOCATOR_STATS": "OFF",
          "OPENCV_TRACE": "OFF",
          "OPENCV_BIN_INSTALL_PATH": "bin",
          "OPENCV_LIB_INSTALL_PATH": "lib",
          "OPENCV_INCLUDE_INSTALL_PATH": "include",
          "OPENCV_CONFIG_INSTALL_PATH": "lib/cmake/opencv4"
        },
        "cmake_options_by_config": {
          "release": {
            "BUILD_LIST": "core,imgproc,imgcodecs",
            "BUILD_opencv_dnn": "OFF",
            "BUILD_opencv_highgui": "OFF",
            "BUILD_opencv_videoio": "OFF",
            "ENABLE_LTO": "ON",
            "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
            "CMAKE_C_FLAGS_RELEASE": "/O2 /Ob2 /DNDEBUG /Gy /Gw",
            "CMAKE_CXX_FLAGS_RELEASE": "/O2 /Ob2 /DNDEBUG /Gy /Gw /Zc:inline",
            "CMAKE_SHARED_LINKER_FLAGS_RELEASE": "/INCREMENTAL:NO /OPT:REF /OPT:ICF"
          },
          "debug": {
            "BUILD_LIST": "core,imgproc,imgcodecs,dnn,highgui",
            "BUILD_opencv_highgui": "ON",
            "BUILD_opencv_videoio": "OFF",
            "WITH_WIN32UI": "ON",
            "ENABLE_LTO": "OFF"
          }
        },
        "environment": {
          "OPENCV_DOWNLOAD_PATH": "${BAAS_DOWNLOADS_ROOT}/opencv-download-cache"
        }
      },
      "outputs": {
        "windows": {
          "release": {
            "include": [
              "include/opencv2/core.hpp"
            ],
            "runtime": [
              "bin/opencv_world490.dll"
            ],
            "link": [
              "lib/opencv_world490.lib"
            ]
          },
          "debug": {
            "include": [
              "include/opencv2/core.hpp",
              "include/opencv2/highgui.hpp"
            ],
            "runtime": [
              "bin/opencv_world490d.dll"
            ],
            "link": [
              "lib/opencv_world490d.lib"
            ]
          }
        },
        "linux": {
          "include": [
            "include/opencv2/core.hpp"
          ],
          "runtime": [
            "lib/libopencv_world.so*"
          ],
          "link": [
            "lib/libopencv_world.so"
          ]
        },
        "macos": {
          "include": [
            "include/opencv2/core.hpp"
          ],
          "runtime": [
            "lib/libopencv_world*.dylib"
          ],
          "link": [
            "lib/libopencv_world.dylib"
          ]
        },
        "android": {
          "include": [
            "sdk/native/jni/include/opencv2/core.hpp"
          ],
          "runtime": [
            "sdk/native/libs/${android_abi}/libopencv_java4.so"
          ],
          "link": [
            "sdk/native/libs/${android_abi}/libopencv_java4.so"
          ]
        }
      },
      "validation": {
        "required_headers": [
          "opencv2/core.hpp",
          "opencv2/imgproc.hpp",
          "opencv2/imgcodecs.hpp"
        ],
        "required_outputs": [
          "include",
          "runtime",
          "link"
        ]
      }
    },
